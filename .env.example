# APEX CRM — Railway Environment Variables
# Add ALL of these in Railway → Variables tab before deploying

# Telnyx
TELNYX_API_KEY=YOUR_TELNYX_API_KEY_HERE
TELNYX_APP_ID=2956764013855246110
# Outbound Call Control connection_id (used for /api/calls/dial)
TELNYX_CONNECTION_ID=YOUR_TELNYX_CONNECTION_ID_HERE
TELNYX_CALLER_ID=+1YOUR_PHONE_NUMBER_HERE
TELNYX_OUTBOUND_PROFILE_ID=YOUR_OUTBOUND_PROFILE_ID_HERE

# Supabase
SUPABASE_URL=https://sdlosxhgqakrumhtzsns.supabase.co
SUPABASE_SERVICE_KEY=YOUR_SUPABASE_SERVICE_ROLE_KEY_HERE

# App
BASE_URL=https://apex-crm.railway.app
PORT=3000

# SIP Passwords for each agent (from Telnyx SIP credentials)
# These get injected into the frontend via /api/config endpoint
SIP_PASS_APEXJORDAN=YOUR_APEXJORDAN_SIP_PASSWORD
SIP_PASS_APEXBRENT=YOUR_APEXBRENT_SIP_PASSWORD
SIP_PASS_APEXGLENN=YOUR_APEXGLENN_SIP_PASSWORD
SIP_PASS_APEXJESSICA=YOUR_APEXJESSICA_SIP_PASSWORD
SIP_PASS_APEXKEMAIN=YOUR_APEXKEMAIN_SIP_PASSWORD
